{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./out",
    "rootDir": "../../..",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "baseUrl": "../../..",
    "paths": {
      "@bonsai/types": ["./packages/types/index"],
      "@bonsai/rxjs": ["./packages/rxjs/src/rxjs"],
      "@bonsai/immer": ["./packages/immer/src/immer"],
      "@bonsai/valibot": ["./packages/valibot/src/valibot"],
      "@bonsai/event": ["./packages/event/src/bonsai-event"]
    }
  },
  "include": [
    "../../../core/src/**/*.ts",
    "../../../packages/rxjs/src/**/*.ts",
    "../../../packages/immer/src/**/*.ts",
    "../../../packages/valibot/src/**/*.ts",
    "../../../packages/event/src/**/*.ts"
  ]
}
