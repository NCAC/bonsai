{
  "extends": "../tsconfig.framework.json",
  "compilerOptions": {
    "rootDir": "..",
    "paths": {
      "@build/*": ["../lib/build/*"],
      "bonsai/lib/*": ["../lib/*"],
      "bonsai": ["./dist"],
      "@bonsai/types": ["../packages/types/index.d.ts"],
      "@bonsai/types/*": ["../packages/types/src/*"],
      "@bonsai/rxjs": ["../packages/rxjs/src/rxjs"],
      "@bonsai/immer": ["../packages/immer/src/immer"],
      "@bonsai/valibot": ["../packages/valibot/src/valibot"],
      "@bonsai/event": ["../packages/event/src/bonsai-event"],
      "@bonsai/event/*": ["../packages/event/src/*"]
    }
  },
  "include": ["src"]
}
