{
  "name": "bonsai",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/NCAC/bonsai.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "author": {
    "name": "NCAC",
    "email": "dev.ncac@gmail.com"
  },
  "browserslist": [
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsx --expose-gc ./lib/build.ts",
    "build:clean": "pnpm run build --clean",
    "build:no-watch": "pnpm run build --no-watch",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "test:ci": "npx jest --ci --coverage --watchAll=false",
    "test:unit": "npx jest tests/unit",
    "test:integration": "npx jest tests/integration",
    "test:e2e": "npx jest tests/e2e",
    "test:regression": "npx jest --testPathPattern='regression\\.test\\.ts$' --no-coverage",
    "test:strate-0:regression": "npx jest tests/unit/strate-0/strate-0.regression.test.ts --no-coverage",
    "tsc:check": "tsc --noEmit"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "."
  ],
  "dependencies": {
    "@bonsai/core": "workspace:^",
    "@bonsai/entity": "workspace:^",
    "@bonsai/event": "workspace:^",
    "@bonsai/feature": "workspace:^",
    "@bonsai/immer": "workspace:^",
    "@bonsai/rxjs": "workspace:^",
    "@bonsai/types": "workspace:^",
    "@bonsai/valibot": "workspace:^",
    "@bonsai/view": "workspace:^",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.15.31",
    "@types/pretty-hrtime": "^1.0.3",
    "@types/vinyl-fs": "^3.0.6",
    "camelcase": "^8.0.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "gulp-prettier": "^6.0.0",
    "immer": "^11.1.4",
    "js-yaml": "^4.1.0",
    "magic-string": "^0.30.17",
    "minimist": "^1.2.8",
    "package-json-type": "^1.0.3",
    "pretty-hrtime": "^1.0.3",
    "remeda": "^2.23.0",
    "rollup": "^4.44.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "rxjs": "^7.8.2",
    "slash": "^5.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3",
    "type-fest": "^4.41.0",
    "typescript": "^5.8.3",
    "valibot": "^1.3.1",
    "vinyl-fs": "^4.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ora": "^8.2.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2"
  }
}
