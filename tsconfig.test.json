{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "@jest/globals", "node"],
    "lib": ["ESNext", "DOM"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      // Résolution via package.json des modules @bonsai/* (workspace pnpm)
    }
  },
  "include": [
    "tests/**/*",
    "packages/*/src/**/*.ts",
    "core/src/**/*.test.ts",
    "packages/**/*.test.ts",
    "lib/**/*.test.ts",
    "tools/**/*.test.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
