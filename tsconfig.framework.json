      // "@bonsai/region*": ["packages/region/dist"],
      // "@bonsai/app-node*": ["packages/app-node/dist"],
      // "bonsai-pug-ts*": ["tools/pug-ts/dist"]
    }
  },

  "include": ["core/src", "tests"],
  "references": [
    { "path": "./packages/types" },
