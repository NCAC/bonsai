      "bonsai": ["./core/dist"],
      "@bonsai/types": ["./packages/types/index.d.ts"],
      "@bonsai/types/*": ["./packages/types/src/*"],
      "@bonsai/rxjs": ["./packages/rxjs/src/rxjs"],
